# Copyright (c) 2026 ResQ
#
# Example environment configuration for ResQ Health Checker
# Rust tool using std::env for configuration
# Copy this file to .env and update with your actual values
#
# Usage:
#   export $(cat .env | xargs) && cargo run

# ─────────────────────────────────────────────
# Service Endpoints
# All URLs are optional and have sensible defaults
# ─────────────────────────────────────────────

# [optional] Coordination HCE health endpoint
HCE_URL=http://localhost:5000

# [optional] Infrastructure API health endpoint
INFRA_API_URL=http://localhost:5000

# [optional] Intelligence PDIE health endpoint
PDIE_URL=http://localhost:8000

# ─────────────────────────────────────────────
# External Infrastructure
# ─────────────────────────────────────────────

# [optional] Neo N3 RPC endpoint for blockchain health check
NEO_RPC_URL=http://localhost:20332

# [optional] IPFS gateway endpoint for storage health check
IPFS_URL=http://localhost:8081

# ─────────────────────────────────────────────
# Advanced Configuration
# ─────────────────────────────────────────────

# [optional] Health check timeout in milliseconds
# HEALTH_CHECK_TIMEOUT_MS=5000

# [optional] Number of retries for failed checks
# HEALTH_CHECK_RETRIES=3

# [optional] Enable verbose output
# HEALTH_CHECK_VERBOSE=false
