#!/usr/bin/env bash
# Repo-specific pre-push — runs alongside the canonical ResQ pre-push hook.
# Generated by `resq dev scaffold-local-hook --kind dotnet`.
# Mirrors the typical CI gates: format verify + Release build.
set -euo pipefail

if ! command -v dotnet >/dev/null 2>&1; then
    echo "  skipping .NET checks (dotnet not installed)" >&2
    exit 0
fi

echo "  .NET: dotnet format --verify-no-changes"
if ! dotnet format --verify-no-changes --verbosity diagnostic; then
    echo "❌ dotnet format would change files. Run 'dotnet format' and commit."
    exit 1
fi

echo "  .NET: dotnet build -c Release"
dotnet build --configuration Release --nologo --verbosity minimal
