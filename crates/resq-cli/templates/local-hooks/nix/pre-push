#!/usr/bin/env bash
# Repo-specific pre-push — runs alongside the canonical ResQ pre-push hook.
# Generated by `resq dev scaffold-local-hook --kind nix`.
set -euo pipefail

if command -v nix >/dev/null 2>&1 && [ -f flake.nix ]; then
    echo "  Nix: nix flake check --no-build"
    nix flake check --no-build
else
    echo "  skipping nix flake check (nix not installed or no flake.nix)" >&2
fi
